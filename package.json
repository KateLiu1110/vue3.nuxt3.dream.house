{
  "name": "nuxt-app",
  "type": "module",
  "version": "0.0.128",
  "private": true,
  "scripts": {
    "build:ncc": "npm run build && npm run ncc && npm run del && npm run rndir",
    "ncc": "ncc build .output/server/index.mjs -o .output/ncc-server",
    "del": "rimraf .output/server",
    "rndir": "renamer --find \"ncc-server\" --replace \"server\" \"./.output/**\"",
    "build": "nuxt build",
    "dev": "nuxt dev --host",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "runProdForWin": "$env:PORT='3455'; node .\\.output\\server\\index.mjs",
    "release": "release-it",
    "generate": "nuxt generate",
    "deploy": "npm run generate && gh-pages -d .output/public"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.18.1",
    "@element-plus/icons-vue": "^2.3.1",
    "@element-plus/nuxt": "^1.1.1",
    "@handsontable/vue3": "^15.2.0",
    "@pinia/nuxt": "^0.11.3",
    "@release-it/conventional-changelog": "^9.0.3",
    "@sidebase/nuxt-auth": "^0.9.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "20",
    "@unocss/eslint-plugin": "^0.60.2",
    "@unocss/nuxt": "^66.6.2",
    "@vee-validate/rules": "^4.13.1",
    "@vercel/ncc": "^0.38.1",
    "@vue/devtools-api": "^6.6.3",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.4.3",
    "element-plus": "^2.9.4",
    "eslint": "^9.3.0",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.1",
    "gh-pages": "^6.3.0",
    "h3-formidable": "^1.0.0",
    "imask": "^7.6.1",
    "jsonwebtoken": "^9.0.2",
    "nuxt": "^3.16.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.0.0",
    "release-it": "^17.10.0",
    "renamer": "^5.0.1",
    "request": "^2.88.2",
    "rimraf": "^5.0.7",
    "sass": "^1.69.7",
    "typescript": "^5.4.5",
    "unocss": "^66.6.2",
    "vee-validate": "^4.13.1",
    "vue": "^3.4.38",
    "vue-imask": "^7.6.1",
    "vue-router": "^4.4.3",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5",
    "yup": "^1.4.0"
  },
  "dependencies": {
    "echarts": "^5.5.0",
    "handsontable": "^15.2.0",
    "lucide-vue-next": "^0.575.0",
    "nuxt-icon": "^1.0.0-beta.7"
  }
}
